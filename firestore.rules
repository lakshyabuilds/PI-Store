rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      // Hardcode admin email for bootstrapping MVP as requested
      return (isSignedIn() && request.auth.token.get('email', '') == 'lakshya.automate@gmail.com') ||
             (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // 1. Users
    function isValidUser(data) {
      return data.keys().hasAll(['role', 'email'])
        && data.role in ['admin', 'user']
        && data.email is string
        && (data.get('name', null) == null || data.name is string)
        && (data.get('storeId', null) == null || data.storeId is string)
        && (data.get('createdAt', null) == null || data.createdAt is timestamp || data.createdAt is string);
    }
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
                    && (incoming().role == 'user' || incoming().email == 'lakshya.automate@gmail.com' || isAdmin()); // only admin can create an admin
      allow update: if (isAdmin() && isValidUser(incoming())) ||
                    (isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().role == existing().role);
    }
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 2. Categories
    function isValidCategory(data) {
      return data.keys().hasAll(['name'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }
    match /categories/{categoryId} {
       allow read: if true; // Public for store viewing
       allow create, update: if isAdmin() && isValidCategory(incoming());
       allow delete: if isAdmin();
    }

    // 3. Products
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'status'])
        && data.title is string && data.title.size() <= 200
        && data.status in ['active', 'draft', 'archived']
        && (data.get('categoryId', null) == null || (data.categoryId is string && data.categoryId.size() <= 128))
        && (data.get('shortDescription', null) == null || (data.shortDescription is string && data.shortDescription.size() <= 500))
        && (data.get('longDescription', null) == null || (data.longDescription is string && data.longDescription.size() <= 5000))
        && (data.get('thumbnail', null) == null || (data.thumbnail is string && data.thumbnail.size() <= 1024))
        && (data.get('fileUrl', null) == null || (data.fileUrl is string && data.fileUrl.size() <= 1024))
        && (data.get('price', null) == null || data.price is number)
        && (data.get('tags', null) == null || (data.tags is list && data.tags.size() <= 20))
        && (data.get('createdAt', null) == null || data.createdAt is timestamp || data.createdAt is string);
    }
    match /products/{productId} {
      allow read: if true; // Public for store viewing
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 4. Stores
    function isValidStore(data) {
      return data.keys().hasAll(['ownerId', 'name', 'slug'])
        && data.ownerId is string
        && data.name is string && data.name.size() <= 100
        && data.slug is string && data.slug.matches('^[a-z0-9-]+$')
        && (data.get('logo', null) == null || data.logo is string)
        && (data.get('brandColor', null) == null || (data.brandColor is string && data.brandColor.size() <= 20))
        && (data.get('bio', null) == null || data.bio is string)
        && (data.get('selectedProductIds', null) == null || data.selectedProductIds is list)
        && (data.get('createdAt', null) == null || data.createdAt is timestamp || data.createdAt is string);
    }
    match /stores/{storeId} {
      allow read: if true; // Public for storefront
      allow create: if isSignedIn() && isValidStore(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if (isAdmin() && isValidStore(incoming())) ||
                    (isSignedIn() && existing().ownerId == request.auth.uid && isValidStore(incoming()) && incoming().ownerId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    // 5. Leads (public can create, owner/admin can read/update)
    function isValidLead(data) {
      return data.keys().hasAll(['storeId', 'status', 'createdAt'])
        && data.storeId is string && data.storeId.size() <= 128
        && data.status in ['new', 'contacted', 'interested', 'won', 'lost']
        && (data.get('productId', null) == null || (data.productId is string && data.productId.size() <= 128))
        && (data.get('name', null) == null || (data.name is string && data.name.size() <= 100))
        && (data.get('email', null) == null || (data.email is string && data.email.size() <= 256))
        && (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 50))
        && (data.get('source', null) == null || (data.source is string && data.source.size() <= 100))
        && (data.get('notes', null) == null || (data.notes is string && data.notes.size() <= 5000))
        && (data.get('salesValue', null) == null || data.salesValue is number)
        && (data.createdAt is timestamp || data.createdAt is string || data.createdAt is number);
    }
    match /leads/{leadId} {
      allow create: if isValidLead(incoming()) && incoming().status == 'new';
      
      function canAccessLead() {
        // Since storeId is the same as the owner's uid (simplified in StoreBuilder), we can just check this directly.
        return isAdmin() || 
               (isSignedIn() && existing().storeId == request.auth.uid);
      }
      allow read: if canAccessLead();
      allow update: if canAccessLead() && isValidLead(incoming()) && incoming().storeId == existing().storeId;
      allow delete: if canAccessLead();
    }

    // 6. CRM Notes
    function isValidCrmNote(data) {
      return data.keys().hasAll(['leadId', 'note', 'createdBy', 'createdAt'])
        && data.leadId is string && data.leadId.size() <= 128
        && data.note is string && data.note.size() > 0 && data.note.size() <= 5000
        && data.createdBy is string && data.createdBy.size() <= 128
        && (data.createdAt is timestamp || data.createdAt is string);
    }
    match /crmNotes/{noteId} {
      allow read: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
      allow create: if isSignedIn() && isValidCrmNote(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidCrmNote(incoming()) && existing().createdBy == request.auth.uid && incoming().leadId == existing().leadId;
      allow delete: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
    }
  }
}
